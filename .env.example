# Gemini (defaults to Gemini when GEMINI_API_KEY / GOOGLE_API_KEY / Gemini_API_Key is set)
GEMINI_API_KEY=

# Optional: gemini | anthropic when you have both keys (otherwise auto-selected)
# LLM_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic (when LLM_PROVIDER=anthropic or no Gemini key)
ANTHROPIC_API_KEY=

# Django
DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key

# Database (SQLite by default - uncomment for PostgreSQL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=codebase_research
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
